RESUMEIQ_APP_NAME=ResumeIQ API
RESUMEIQ_ENVIRONMENT=development
RESUMEIQ_API_VERSION=v1
RESUMEIQ_APP_VERSION=0.1.0
RESUMEIQ_LOG_LEVEL=INFO
RESUMEIQ_DATABASE_URL=postgresql+asyncpg://resumeiq:resumeiq@localhost:5432/resumeiq
RESUMEIQ_DATABASE_POOL_SIZE=10
RESUMEIQ_DATABASE_MAX_OVERFLOW=20
RESUMEIQ_REDIS_URL=redis://localhost:6379/0
RESUMEIQ_QDRANT_URL=http://localhost:6333
RESUMEIQ_ALLOWED_ORIGINS=["http://localhost:3000"]
RESUMEIQ_OPENROUTER_API_KEY=
RESUMEIQ_AWS_REGION=
RESUMEIQ_AWS_S3_BUCKET=
